---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import {
  compareEssaysByDateDesc,
  formatEssayDate,
  getEssayKeywords,
  getEssaySlug,
  getEssayUrl,
  type Essay,
} from "../../lib/essays";

export async function getStaticPaths() {
  const essays = (await getCollection("essays", ({ data }) => data.draft !== true)).sort(
    compareEssaysByDateDesc,
  );

  return essays.map((essay) => ({
    params: { slug: getEssaySlug(essay) },
    props: { essay },
  }));
}

interface Props {
  essay: Essay;
}

const { essay } = Astro.props;
const { Content, headings } = await render(essay);
const keywords = getEssayKeywords(essay);
const tocHeadings = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
const hasToc = tocHeadings.length >= 2;
---

<Layout
  title={essay.data.title}
  description={essay.data.description}
  canonicalPath={getEssayUrl(essay)}
  ogType="article"
  keywords={keywords}
>
  <main class="page-shell article-shell">
    <article>
      <header class="article-header">
        <p class="essay-meta">{formatEssayDate(essay.data.date)}</p>
        <h1 class="article-title">{essay.data.title}</h1>
        <p class="article-description">{essay.data.description}</p>
        {
          keywords.length > 0 && (
            <div class="article-keywords">
              <span class="keyword-label">关键词</span>
              <ul class="keyword-row">
                {keywords.map((keyword) => (
                  <li class="keyword">{keyword}</li>
                ))}
              </ul>
            </div>
          )
        }
        {
          essay.data.doi && (
            <p class="article-doi">
              DOI <a href={essay.data.doi}>{essay.data.doi.replace("https://doi.org/", "")}</a>
            </p>
          )
        }
      </header>

      <div class="article-body">
        {
          hasToc && (
            <aside class="article-toc" aria-labelledby="article-toc-title">
              <p id="article-toc-title" class="article-toc-title">
                目录
              </p>
              <ol class="article-toc-list">
                {tocHeadings.map((heading) => (
                  <li class:list={["article-toc-item", `depth-${heading.depth}`]}>
                    <a href={`#${heading.slug}`}>{heading.text}</a>
                  </li>
                ))}
              </ol>
            </aside>
          )
        }

        <div class="prose">
          <Content />
        </div>
      </div>
    </article>
  </main>
</Layout>

<style>
  .article-shell {
    padding-top: 58px;
  }

  .article-header {
    max-width: 780px;
    margin-bottom: 56px;
    padding-bottom: 34px;
    border-bottom: 1px solid var(--line);
  }

  .article-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 36px;
  }

  .article-title {
    margin: 0 0 18px;
    font-size: clamp(2.1rem, 7vw, 4.2rem);
    line-height: 1.18;
    letter-spacing: 0;
  }

  .article-description {
    max-width: 700px;
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .prose {
    max-width: 780px;
  }

  .article-toc {
    padding: 18px 20px 20px;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--surface);
  }

  .article-toc-title {
    margin: 0 0 12px;
    color: var(--faint);
    font-size: 0.76rem;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .article-toc-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .article-toc-item {
    margin: 0;
    color: var(--muted);
    font-size: 0.94rem;
    line-height: 1.65;
  }

  .article-toc-item + .article-toc-item {
    margin-top: 0.45rem;
  }

  .article-toc-item.depth-3 {
    padding-left: 1rem;
    color: var(--faint);
    font-size: 0.88rem;
  }

  .article-toc-item a {
    text-decoration: underline;
    text-decoration-color: transparent;
  }

  .article-toc-item a:hover {
    text-decoration-color: currentColor;
  }

  .article-keywords {
    margin-top: 22px;
  }

  .article-keywords .keyword-row {
    margin-top: 8px;
  }

  .article-doi {
    margin: 18px 0 0;
    color: var(--faint);
    font-size: 0.82rem;
  }

  .article-doi a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }

  @media (min-width: 980px) {
    .article-shell {
      width: min(100% - 40px, 1080px);
    }

    .article-body {
      grid-template-columns: minmax(0, 780px) 220px;
      align-items: start;
    }

    .article-toc {
      position: sticky;
      top: 28px;
      order: 2;
    }

    .prose {
      order: 1;
    }
  }

  @media (max-width: 620px) {
    .article-shell,
    .article-header,
    .prose,
    .article-description {
      max-width: none;
    }
  }
</style>
