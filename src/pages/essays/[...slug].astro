---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import {
  compareEssaysByDateDesc,
  formatEssayDate,
  getEssayKeywords,
  getEssaySlug,
  getEssayUrl,
  type Essay,
} from "../../lib/essays";

export async function getStaticPaths() {
  const essays = (await getCollection("essays", ({ data }) => data.draft !== true)).sort(
    compareEssaysByDateDesc,
  );

  return essays.map((essay) => ({
    params: { slug: getEssaySlug(essay) },
    props: { essay },
  }));
}

interface Props {
  essay: Essay;
}

const { essay } = Astro.props;
const { Content } = await render(essay);
const keywords = getEssayKeywords(essay);
---

<Layout
  title={essay.data.title}
  description={essay.data.description}
  canonicalPath={getEssayUrl(essay)}
  ogType="article"
  keywords={keywords}
>
  <main class="page-shell article-shell">
    <article>
      <header class="article-header">
        <p class="essay-meta">{formatEssayDate(essay.data.date)}</p>
        <h1 class="article-title">{essay.data.title}</h1>
        <p class="article-description">{essay.data.description}</p>
        {
          keywords.length > 0 && (
            <div class="article-keywords">
              <span class="keyword-label">关键词</span>
              <ul class="keyword-row">
                {keywords.map((keyword) => (
                  <li class="keyword">{keyword}</li>
                ))}
              </ul>
            </div>
          )
        }
        {
          essay.data.doi && (
            <p class="article-doi">
              DOI <a href={essay.data.doi}>{essay.data.doi.replace("https://doi.org/", "")}</a>
            </p>
          )
        }
      </header>

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .article-shell {
    padding-top: 58px;
  }

  .article-header {
    margin-bottom: 56px;
    padding-bottom: 34px;
    border-bottom: 1px solid var(--line);
  }

  .article-title {
    margin: 0 0 18px;
    font-size: clamp(2.1rem, 7vw, 4.2rem);
    line-height: 1.18;
    letter-spacing: 0;
  }

  .article-description {
    max-width: 640px;
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
    line-height: 1.8;
  }

  .article-keywords {
    margin-top: 22px;
  }

  .article-keywords .keyword-row {
    margin-top: 8px;
  }

  .article-doi {
    margin: 18px 0 0;
    color: var(--faint);
    font-size: 0.82rem;
  }

  .article-doi a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 0.18em;
  }
</style>
