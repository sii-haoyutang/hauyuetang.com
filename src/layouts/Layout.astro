---
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
  keywords?: string[];
  backgroundTrackWidth?: string;
}

const {
  title,
  description = "兴来每独往，胜事空自知。",
  canonicalPath = Astro.url.pathname,
  ogType = "website",
  keywords = [],
  backgroundTrackWidth = "880px",
} = Astro.props;

const siteName = "Hauyue Tang";
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const siteUrl = Astro.site ?? new URL("https://hauyuetang.com");
const canonicalUrl = new URL(canonicalPath, siteUrl).href;
const keywordContent = [...new Set(keywords)].join(", ");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="alternate icon" href="/favicon.ico?v=2" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    <meta name="description" content={description} />
    {keywordContent && <meta name="keywords" content={keywordContent} />}
    <meta name="generator" content={Astro.generator} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body style={`--background-track-width: ${backgroundTrackWidth};`}>
    <header class="site-header">
      <a class="site-title" href="/" aria-label="Hauyue Tang 首页">Hauyue Tang</a>
      <nav aria-label="主导航">
        <a href="/essays/">Essays</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Hauyue Tang</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --background: #faf8f2;
    --text: #0f0f0e;
    --muted: #60605a;
    --faint: #929088;
    --line: #ded8ca;
    --accent: #9a6a2f;
    --accent-soft: #eadfcb;
    --surface: #f1ede3;
    --surface-strong: #e8e1d2;
    font-family:
      "Noto Serif SC", "Source Han Serif SC", "Songti SC", Georgia, "Times New Roman",
      serif;
    font-size: 17px;
    line-height: 1.75;
    letter-spacing: 0;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --background: #11100e;
      --text: #f0ece3;
      --muted: #b7b2a8;
      --faint: #878276;
      --line: #302c25;
      --accent: #caa46d;
      --accent-soft: #342b1f;
      --surface: #1b1915;
      --surface-strong: #242018;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--background);
    color: var(--text);
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body {
    margin: 0;
    min-width: 320px;
    background:
      linear-gradient(
          90deg,
          color-mix(in srgb, var(--line) 38%, transparent) 1px,
          transparent 1px
        )
        center top / min(100% - 40px, var(--background-track-width)) 100% no-repeat,
      var(--background);
    color: var(--text);
  }

  body::before {
    display: block;
    height: 4px;
    background: linear-gradient(90deg, var(--accent), var(--line));
    content: "";
  }

  a {
    color: inherit;
    text-decoration: none;
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--accent);
  }

  p,
  h1,
  h2,
  h3,
  h4,
  blockquote,
  figure {
    margin-top: 0;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .site-header,
  .site-footer,
  .page-shell {
    width: min(100% - 40px, 800px);
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 30px 0 24px;
    border-bottom: 1px solid var(--line);
  }

  .site-title {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
  }

  .site-title::after {
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--accent);
    content: "";
  }

  nav {
    display: flex;
    align-items: center;
    gap: 22px;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1;
  }

  .site-footer {
    padding: 64px 0 42px;
    color: var(--faint);
    font-size: 0.82rem;
  }

  .site-footer p {
    margin: 0;
  }

  .page-shell {
    padding: 64px 0 40px;
  }

  .page-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 16px;
    color: var(--faint);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .page-kicker::before {
    width: 28px;
    height: 1px;
    background: var(--accent);
    content: "";
  }

  .page-title {
    margin-bottom: 30px;
    font-size: clamp(2.4rem, 8vw, 4.8rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .page-intro {
    max-width: 620px;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.85;
  }

  .section-heading {
    margin: 0 0 22px;
    color: var(--faint);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .essay-list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .essay-item {
    padding: 28px 0 32px;
    border-bottom: 1px solid var(--line);
    transition:
      border-color 160ms ease,
      padding-left 160ms ease;
  }

  .essay-item:hover {
    padding-left: 10px;
    border-color: color-mix(in srgb, var(--accent) 45%, var(--line));
  }

  .essay-meta {
    margin-bottom: 8px;
    color: var(--faint);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .essay-title {
    margin: 0 0 10px;
    font-size: clamp(1.45rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.28;
  }

  .essay-description {
    margin: 0;
    max-width: 640px;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .keyword-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    margin: 16px 0 0;
    padding: 0;
    list-style: none;
  }

  .keyword {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.18rem 0.62rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--surface);
    color: var(--muted);
    font-size: 0.76rem;
    line-height: 1.25;
  }

  .keyword-label {
    color: var(--faint);
    font-size: 0.76rem;
  }

  .prose {
    max-width: 720px;
    color: var(--text);
    font-size: clamp(1.02rem, 2vw, 1.12rem);
    line-height: 2;
  }

  .prose > * + * {
    margin-top: 1.2em;
  }

  .prose h2,
  .prose h3,
  .prose h4 {
    margin-top: 2.2em;
    margin-bottom: 0.65em;
    line-height: 1.35;
  }

  .prose h2 {
    font-size: 1.45rem;
  }

  .prose h3 {
    font-size: 1.2rem;
  }

  .prose p {
    margin-bottom: 0;
    text-indent: 2em;
  }

  .prose figure {
    margin: 1.8em 0;
  }

  .prose figure img {
    display: block;
    width: 100%;
    height: auto;
    margin: 0 auto;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--surface);
  }

  .prose figcaption {
    margin-top: 0.72rem;
    color: var(--muted);
    font-size: 0.92rem;
    line-height: 1.75;
    text-align: center;
    text-indent: 0;
  }

  .prose blockquote p,
  .prose li p,
  .prose figcaption {
    text-indent: 0;
  }

  .prose .katex-display {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.4rem 0;
    text-indent: 0;
  }

  .prose .katex-display + p {
    text-indent: 0;
  }

  .prose a {
    color: var(--accent);
    text-decoration: underline;
  }

  .prose blockquote {
    margin-left: 0;
    padding-left: 1.1rem;
    border-left: 2px solid var(--line);
    color: var(--muted);
  }

  .prose code {
    padding: 0.12em 0.32em;
    border-radius: 4px;
    background: var(--surface);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.86em;
  }

  .prose pre {
    overflow-x: auto;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--surface);
  }

  .prose pre code {
    padding: 0;
    background: transparent;
  }

  @media (max-width: 620px) {
    :root {
      font-size: 16px;
    }

    .prose .katex-display > .katex > .katex-html > .tag {
      position: static;
      display: block;
      margin-top: 0.45rem;
      text-align: right;
    }

    .site-header {
      align-items: flex-start;
      padding-top: 24px;
    }

    nav {
      gap: 14px;
      font-size: 0.88rem;
    }

    .page-shell {
      padding-top: 48px;
    }
  }
</style>
