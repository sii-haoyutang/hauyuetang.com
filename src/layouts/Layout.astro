---
import "katex/dist/katex.min.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
}

const {
  title,
  description = "关于政治、科学与现代世界的随笔与评论。",
  canonicalPath = Astro.url.pathname,
  ogType = "website",
} = Astro.props;

const siteName = "Hauyue Tang";
const pageTitle = title ? `${title} | ${siteName}` : siteName;
const siteUrl = Astro.site ?? new URL("https://hauyuetang.com");
const canonicalUrl = new URL(canonicalPath, siteUrl).href;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/" aria-label="Hauyue Tang 首页">Hauyue Tang</a>
      <nav aria-label="主导航">
        <a href="/essays/">Essays</a>
        <a href="/about/">About</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} Hauyue Tang</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light dark;
    --background: #fbfaf7;
    --text: #101010;
    --muted: #5e5a54;
    --faint: #8a857d;
    --line: #ded8cc;
    --accent: #7a2e22;
    --surface: #f4f0e8;
    font-family:
      "Noto Serif SC", "Source Han Serif SC", "Songti SC", Georgia, "Times New Roman",
      serif;
    font-size: 17px;
    line-height: 1.75;
    letter-spacing: 0;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --background: #12110f;
      --text: #f3eee6;
      --muted: #b8aea1;
      --faint: #8c8378;
      --line: #342f28;
      --accent: #d7a171;
      --surface: #1a1815;
    }
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--background);
    color: var(--text);
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
  }

  body {
    margin: 0;
    min-width: 320px;
    background: var(--background);
    color: var(--text);
  }

  a {
    color: inherit;
    text-decoration: none;
    text-underline-offset: 0.18em;
  }

  a:hover {
    color: var(--accent);
  }

  p,
  h1,
  h2,
  h3,
  h4,
  blockquote,
  figure {
    margin-top: 0;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  .site-header,
  .site-footer,
  .page-shell {
    width: min(100% - 40px, 800px);
    margin-inline: auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 30px 0 24px;
  }

  .site-title {
    font-size: 1rem;
    font-weight: 700;
    line-height: 1;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 22px;
    color: var(--muted);
    font-size: 0.9rem;
    line-height: 1;
  }

  .site-footer {
    padding: 64px 0 42px;
    color: var(--faint);
    font-size: 0.82rem;
  }

  .site-footer p {
    margin: 0;
  }

  .page-shell {
    padding: 64px 0 40px;
  }

  .page-kicker {
    margin-bottom: 16px;
    color: var(--faint);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .page-title {
    margin-bottom: 30px;
    font-size: clamp(2.4rem, 8vw, 4.8rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: 0;
  }

  .page-intro {
    max-width: 620px;
    color: var(--muted);
    font-size: clamp(1.05rem, 2vw, 1.22rem);
    line-height: 1.85;
  }

  .section-heading {
    margin: 0 0 22px;
    color: var(--faint);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
  }

  .essay-list {
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--line);
  }

  .essay-item {
    padding: 26px 0 30px;
    border-bottom: 1px solid var(--line);
  }

  .essay-meta {
    margin-bottom: 8px;
    color: var(--faint);
    font-size: 0.84rem;
    line-height: 1.5;
  }

  .essay-title {
    margin: 0 0 10px;
    font-size: clamp(1.45rem, 4vw, 2rem);
    font-weight: 700;
    line-height: 1.28;
  }

  .essay-description {
    margin: 0;
    max-width: 640px;
    color: var(--muted);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .prose {
    max-width: 720px;
    color: var(--text);
    font-size: clamp(1.02rem, 2vw, 1.12rem);
    line-height: 2;
  }

  .prose > * + * {
    margin-top: 1.2em;
  }

  .prose h2,
  .prose h3,
  .prose h4 {
    margin-top: 2.2em;
    margin-bottom: 0.65em;
    line-height: 1.35;
  }

  .prose h2 {
    font-size: 1.45rem;
  }

  .prose h3 {
    font-size: 1.2rem;
  }

  .prose p {
    margin-bottom: 0;
  }

  .prose a {
    color: var(--accent);
    text-decoration: underline;
  }

  .prose blockquote {
    margin-left: 0;
    padding-left: 1.1rem;
    border-left: 2px solid var(--line);
    color: var(--muted);
  }

  .prose code {
    padding: 0.12em 0.32em;
    border-radius: 4px;
    background: var(--surface);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: 0.86em;
  }

  .prose pre {
    overflow-x: auto;
    padding: 1rem;
    border: 1px solid var(--line);
    border-radius: 6px;
    background: var(--surface);
  }

  .prose pre code {
    padding: 0;
    background: transparent;
  }

  @media (max-width: 620px) {
    :root {
      font-size: 16px;
    }

    .site-header {
      align-items: flex-start;
      padding-top: 24px;
    }

    nav {
      gap: 14px;
      font-size: 0.88rem;
    }

    .page-shell {
      padding-top: 48px;
    }
  }
</style>
