{
  "editor.rulers": [80, 100],
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,

  "files.exclude": {
    "dist": true,
    ".astro": true,
    "node_modules": true
  },

  "search.exclude": {
    "dist": true,
    ".astro": true,
    "node_modules": true
  },

  "cSpell.words": [
    "Behler",
    "cutoff",
    "DFT",
    "DimeNet",
    "equivariance",
    "equivariant",
    "EFA",
    "EqFormer",
    "Equiformer",
    "ERoPE",
    "MACE",
    "MPNN",
    "MPNNs",
    "NequIP",
    "Parrinello",
    "readout",
    "RoPE",
    "SchNet",
    "self-attention",
    "softmax",
    "KaTeX",
    "LaTeX",
    "ViSNet"
  ],

  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },

  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.lineHeight": 1.8,
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },

  "markdown.styles": ["markdown-preview.css"]
}
