{
  "editor.rulers": [80, 100],
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,

  "files.exclude": {
    "dist": true,
    ".astro": true,
    "node_modules": true
  },

  "search.exclude": {
    "dist": true,
    ".astro": true,
    "node_modules": true
  },

  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },

  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.lineHeight": 1.8,
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  }
}
